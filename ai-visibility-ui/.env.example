# Base URL of the Flask API from Task 1.
# NOTE: this project uses Vite, which requires the VITE_ prefix (not
# REACT_APP_) to expose variables to client code -- functionally
# equivalent to Create React App's REACT_APP_ convention, just Vite's
# required naming. See README for details on this choice.
VITE_API_BASE_URL=http://localhost:5000
